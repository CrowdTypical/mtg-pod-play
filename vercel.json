{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/archidekt/:path*",
      "destination": "/api/archidekt-proxy"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/"
    }
  ]
}
