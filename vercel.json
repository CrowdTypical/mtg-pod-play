{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/archidekt/:match*", "destination": "https://archidekt.com/api/:match*" },
    { "source": "/(.*)", "destination": "/" }
  ]
}