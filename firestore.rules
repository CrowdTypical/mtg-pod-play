rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the user authenticated?
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSignedInAs(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // ---- USERS ----
    // Each user owns their own profile doc and subcollections.
    match /users/{uid} {
      allow read: if isSignedInAs(uid);
      allow create, update: if isSignedInAs(uid);

      match /matchHistory/{matchId} {
        allow read: if isSignedInAs(uid);
        allow write: if isSignedInAs(uid);
      }

      match /decks/{deckId} {
        allow read: if isSignedInAs(uid);
        allow write: if isSignedInAs(uid);
      }
    }

    // ---- SESSIONS ----
    // A session represents one game lobby/match. Any authenticated user
    // can read a session (so they can join via code/link). Writes are
    // governed below.
    match /sessions/{sessionId} {
      allow read: if isAuthenticated();

      // Only the host can create or delete the session document.
      allow create: if isAuthenticated()
                    && request.resource.data.hostUid == request.auth.uid;
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated()
                    && resource.data.hostUid == request.auth.uid;

      // ---- PLAYERS in a session ----
      match /players/{uid} {
        allow read: if isAuthenticated();
        // A user creates/updates only their own player doc.
        allow create, update: if isSignedInAs(uid);
        // Only the host can delete a player (e.g., kick).
        allow delete: if isAuthenticated()
                      && get(/databases/$(database)/documents/sessions/$(sessionId)).data.hostUid == request.auth.uid;
      }

      // ---- COMMANDER DAMAGE tracking ----
      match /commanderDamage/{damageId} {
        allow read: if isAuthenticated();
        // Any player in the session may update commander damage during play.
        allow write: if isAuthenticated();
      }

      // ---- EVENTS log (audit / OBS overlay history) ----
      match /events/{eventId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update, delete: if false;
      }
    }
  }
}